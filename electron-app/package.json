{
  "name": "electron-app",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:ci": "electron-builder --dir"
  },
  "build": {
    "appId": "com.portfolio.gpsmarkerviewer",
    "productName": "GPS Marker Viewer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!.env.local",
      "!**/*.md",
      "!screenshots/**"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@googlemaps/markerclusterer": "^2.6.2",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.5",
    "usb": "^2.17.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
